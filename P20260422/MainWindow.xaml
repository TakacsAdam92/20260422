<Window x:Class="P20260422.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P20260422"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="button" Content="Button" Height="39" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0" Click="button_Click"/>
        <DataGrid x:Name="dataGrid" HorizontalAlignment="Center" Height="200" d:ItemsSource="{d:SampleData ItemCount=5}"/>

    </Grid>
</Window>
